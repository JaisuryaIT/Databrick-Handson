{
  "evaluation": {
    "source": {
      "name": "customer_count",
      "display": "source",
      "aggregation": "COUNT"
    },
    "comparison_operator": "LESS_THAN",
    "threshold": {
      "value": {
        "double_value": 100.0
      }
    },
    "empty_result_state": "TRIGGERED",
    "notification": {
      "notify_on_ok": true
    }
  },
  "schedule": {
    "quartz_cron_schedule": "33 4 18 24 * ?",
    "timezone_id": "Asia/Calcutta"
  },
  "query_lines": [
    "SELECT country, customer_count",
    "FROM workspace.default.gold_customer_country_summary",
    "WHERE customer_count > 99"
  ]
}
